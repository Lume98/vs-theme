{
	"name": "Midnight Slate Light",
	"colors": {
		"editor.background": "#fbf8f1db",
		"editor.foreground": "#2d3748",
		"activityBar.background": "#fbf8f1db",
		"activityBar.foreground": "#2d3748",
		"activityBar.inactiveForeground": "#6b7280",
		"activityBar.border": "#d8cfbf",
		"activityBarBadge.background": "#0b6aa2",
		"activityBarBadge.foreground": "#f8fafc",
		"sideBar.background": "#fbf8f1db",
		"sideBar.foreground": "#2d3748",
		"sideBar.border": "#ddd3c3",
		"sideBarTitle.foreground": "#4b5563",
		"sideBarSectionHeader.background": "#ece3d4",
		"sideBarSectionHeader.foreground": "#374151",
		"list.hoverBackground": "#ebe4d8",
		"list.activeSelectionBackground": "#dfe7f5",
		"list.activeSelectionForeground": "#1f2937",
		"list.inactiveSelectionBackground": "#e8edf7",
		"titleBar.activeBackground": "#fbf8f1db",
		"titleBar.activeForeground": "#2d3748",
		"editorGroupHeader.tabsBackground": "#fbf8f1db",
		"tab.activeBackground": "#fbf8f1db",
		"tab.inactiveBackground": "#ece3d4",
		"tab.inactiveForeground": "#6b7280",
		"statusBar.background": "#e7dfd2",
		"statusBar.foreground": "#374151",
		"statusBar.noFolderBackground": "#e7dfd2",
		"statusBar.debuggingBackground": "#d8c8ae",
		"editorLineNumber.foreground": "#9aa3af",
		"editorCursor.foreground": "#0b6aa2",
		"editor.selectionBackground": "#dfe7f5",
		"editor.inactiveSelectionBackground": "#e8edf7",
		"input.background": "#fffdf8",
		"input.foreground": "#2d3748",
		"panel.background": "#fbf8f1db"
	},
	"tokenColors": [
		{
			"name": "Comment",
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"fontStyle": "italic",
				"foreground": "#6b7280"
			}
		},
		{
			"name": "Variables",
			"scope": [
				"variable",
				"string constant.other.placeholder"
			],
			"settings": {
				"foreground": "#2d3748"
			}
		},
		{
			"name": "Colors",
			"scope": [
				"constant.other.color"
			],
			"settings": {
				"foreground": "#1f2937"
			}
		},
		{
			"name": "Invalid",
			"scope": [
				"invalid",
				"invalid.illegal"
			],
			"settings": {
				"foreground": "#c62849"
			}
		},
		{
			"name": "Keyword, Storage",
			"scope": [
				"keyword",
				"storage.type",
				"storage.modifier"
			],
			"settings": {
				"foreground": "#7b3fb6"
			}
		},
		{
			"name": "Operator, Misc",
			"scope": [
				"keyword.control",
				"constant.other.color",
				"punctuation",
				"meta.tag",
				"punctuation.definition.tag",
				"punctuation.separator.inheritance.php",
				"punctuation.definition.tag.html",
				"punctuation.definition.tag.begin.html",
				"punctuation.definition.tag.end.html",
				"punctuation.section.embedded",
				"keyword.other.template",
				"keyword.other.substitution"
			],
			"settings": {
				"foreground": "#0077a8"
			}
		},
		{
			"name": "Tag",
			"scope": [
				"entity.name.tag",
				"meta.tag.sgml",
				"markup.deleted.git_gutter"
			],
			"settings": {
				"foreground": "#b23a48"
			}
		},
		{
			"name": "Function, Special Method",
			"scope": [
				"entity.name.function",
				"meta.function-call",
				"variable.function",
				"support.function",
				"keyword.other.special-method"
			],
			"settings": {
				"foreground": "#2f6fdd"
			}
		},
		{
			"name": "Block Level Variables",
			"scope": [
				"meta.block variable.other"
			],
			"settings": {
				"foreground": "#b23a48"
			}
		},
		{
			"name": "Other Variable, String Link",
			"scope": [
				"support.other.variable",
				"string.other.link"
			],
			"settings": {
				"foreground": "#b23a48"
			}
		},
		{
			"name": "Number, Constant, Function Argument, Tag Attribute, Embedded",
			"scope": [
				"constant.numeric",
				"constant.language",
				"support.constant",
				"constant.character",
				"constant.escape",
				"variable.parameter",
				"keyword.other.unit",
				"keyword.other"
			],
			"settings": {
				"foreground": "#b5472f"
			}
		},
		{
			"name": "String, Symbols, Inherited Class, Markup Heading",
			"scope": [
				"string",
				"constant.other.symbol",
				"constant.other.key",
				"entity.other.inherited-class",
				"markup.heading",
				"markup.inserted.git_gutter",
				"meta.group.braces.curly constant.other.object.key.js string.unquoted.label.js"
			],
			"settings": {
				"foreground": "#2f7d32"
			}
		},
		{
			"name": "Class, Support",
			"scope": [
				"entity.name",
				"support.type",
				"support.class",
				"support.other.namespace.use.php",
				"meta.use.php",
				"support.other.namespace.php",
				"markup.changed.git_gutter",
				"support.type.sys-types"
			],
			"settings": {
				"foreground": "#9c6a00"
			}
		},
		{
			"name": "Entity Types",
			"scope": [
				"support.type"
			],
			"settings": {
				"foreground": "#4b5563"
			}
		},
		{
			"name": "CSS Class and Support",
			"scope": [
				"source.css support.type.property-name",
				"source.sass support.type.property-name",
				"source.scss support.type.property-name",
				"source.less support.type.property-name",
				"source.stylus support.type.property-name",
				"source.postcss support.type.property-name"
			],
			"settings": {
				"foreground": "#4b5563"
			}
		},
		{
			"name": "Sub-methods",
			"scope": [
				"entity.name.module.js",
				"variable.import.parameter.js",
				"variable.other.class.js"
			],
			"settings": {
				"foreground": "#c62849"
			}
		},
		{
			"name": "Language methods",
			"scope": [
				"variable.language"
			],
			"settings": {
				"fontStyle": "italic",
				"foreground": "#c62849"
			}
		},
		{
			"name": "entity.name.method.js",
			"scope": [
				"entity.name.method.js"
			],
			"settings": {
				"fontStyle": "italic",
				"foreground": "#2f6fdd"
			}
		},
		{
			"name": "meta.method.js",
			"scope": [
				"meta.class-method.js entity.name.function.js",
				"variable.function.constructor"
			],
			"settings": {
				"foreground": "#2f6fdd"
			}
		},
		{
			"name": "Attributes",
			"scope": [
				"entity.other.attribute-name"
